# PostgreSQL connection string (Neon, Supabase, Railway, Fly, or local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/velora?schema=public"

# Auth.js — generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Encryption key for stored email app passwords (32-byte base64)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=

# Shared secret for the background sync endpoint (/api/cron/sync)
CRON_SECRET=
