// Velora data model — PostgreSQL.
// Every user-owned row carries userId and is indexed for per-user isolation.
// The core chain: User -> Order -> OrderItem -> Product; delivered items ->
// InventoryStack; selling -> Sale (true margin incl. fees + outbound shipping).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Plan {
  FREE // tracking only
  PRO // full cost/profit/inventory/analytics/share
}

enum EmailProvider {
  GMAIL_IMAP
  IMAP
  INGEST_ADDRESS
}

enum EmailConnectionStatus {
  ACTIVE
  ERROR
  DISCONNECTED
  SYNCING
}

enum ParseStatus {
  PENDING
  PARSED
  FAILED
  IGNORED
}

enum DraftStatus {
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum OrderStatus {
  CONFIRMED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderPriority {
  LOW
  NORMAL
  HIGH
}

enum OrderSource {
  EMAIL
  MANUAL
  IMPORT
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  RETURNED
}

enum InventoryStatus {
  SEALED
}

enum AttachmentType {
  INVOICE
  IMAGE
  FILE
}

enum WebhookKind {
  DISCORD
}

enum NotificationType {
  ORDER_PARSED
  ORDER_SHIPPED
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  ORDER_CANCELLED
  SYSTEM
}

// ─────────────────────────────────────────────────────────────
// Auth (NextAuth-compatible) + User
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  emailConnections  EmailConnection[]
  rawEmails         RawEmail[]
  drafts            ParsedOrderDraft[]
  orders            Order[]
  orderItems        OrderItem[]
  products          Product[]
  matchRules        ProductMatchRule[]
  shipments         Shipment[]
  inventoryStacks   InventoryStack[]
  sales             Sale[]
  attachments       Attachment[]
  notifications     Notification[]
  webhooks          WebhookConfig[]
  shareCards        ShareCard[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Email ingestion + review queue
// ─────────────────────────────────────────────────────────────

model EmailConnection {
  id                 String                @id @default(cuid())
  userId             String
  provider           EmailProvider         @default(GMAIL_IMAP)
  emailAddress       String
  encryptedCredential String               @db.Text // envelope-encrypted app password
  status             EmailConnectionStatus @default(ACTIVE)
  lastSyncedAt       DateTime?
  syncCursor         String? // IMAP UID / history id
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawEmails RawEmail[]

  @@index([userId])
}

model RawEmail {
  id                 String      @id @default(cuid())
  userId             String
  connectionId       String
  messageId          String
  fromAddress        String
  subject            String
  receivedAt         DateTime
  rawRef             String? // blob storage key for the raw message
  detectedRetailerId String?
  parseStatus        ParseStatus @default(PENDING)
  createdAt          DateTime    @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection EmailConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  retailer   Retailer?        @relation(fields: [detectedRetailerId], references: [id])
  draft      ParsedOrderDraft?

  @@unique([connectionId, messageId])
  @@index([userId])
  @@index([parseStatus])
}

model ParsedOrderDraft {
  id            String      @id @default(cuid())
  userId        String
  rawEmailId    String      @unique
  retailerGuess String?
  extractedJson Json // parsed line items, totals, dates before approval
  confidence    Float       @default(0)
  status        DraftStatus @default(NEEDS_REVIEW)
  createdAt     DateTime    @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawEmail RawEmail @relation(fields: [rawEmailId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────────
// Retailers (global, seeded)
// ─────────────────────────────────────────────────────────────

model Retailer {
  id         String  @id @default(cuid())
  name       String
  slug       String  @unique
  logoUrl    String?
  parserKey  String? // maps to a parser implementation
  websiteUrl String?

  orders    Order[]
  rawEmails RawEmail[]
}

// ─────────────────────────────────────────────────────────────
// Orders + line items
// ─────────────────────────────────────────────────────────────

model Order {
  id                String        @id @default(cuid())
  userId            String
  retailerId        String?
  storeLabel        String?
  orderNumber       String
  status            OrderStatus   @default(CONFIRMED)
  priority          OrderPriority @default(NORMAL)
  purchaseDate      DateTime
  deliveryDateEst   DateTime?
  deliveryDateActual DateTime?
  shippingAddress   String?       @db.Text
  accountEmail      String? // the buyer email / account this order belongs to
  subtotal          Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal          Decimal       @default(0) @db.Decimal(12, 2)
  shippingTotal     Decimal       @default(0) @db.Decimal(12, 2)
  discountTotal     Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal        Decimal       @default(0) @db.Decimal(12, 2)
  tags              String[]
  notes             String?       @db.Text
  source            OrderSource   @default(MANUAL)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  retailer    Retailer?    @relation(fields: [retailerId], references: [id])
  items       OrderItem[]
  shipments   Shipment[]
  attachments Attachment[]

  @@unique([userId, retailerId, orderNumber])
  @@index([userId, status])
  @@index([userId, purchaseDate])
}

model OrderItem {
  id                String  @id @default(cuid())
  userId            String
  orderId           String
  productId         String?
  rawName           String // exact text as it appeared in the email
  quantity          Int     @default(1)
  unitPrice         Decimal @default(0) @db.Decimal(12, 2)
  allocatedTax      Decimal @default(0) @db.Decimal(12, 2)
  allocatedShipping Decimal @default(0) @db.Decimal(12, 2)
  allocatedDiscount Decimal @default(0) @db.Decimal(12, 2)
  effectiveUnitCost Decimal @default(0) @db.Decimal(12, 2) // true per-unit cost basis
  createdAt         DateTime @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id])
  inventoryStacks InventoryStack[]

  @@index([userId])
  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
// Products (per-user library) + assisted matching
// ─────────────────────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  userId        String
  canonicalName String
  category      String?
  imageUrl      String?
  upc           String?
  aliases       String[] // raw strings that resolve to this product
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  inventoryStacks InventoryStack[]
  sales           Sale[]
  matchRules      ProductMatchRule[]

  @@index([userId])
  @@index([userId, upc])
}

model ProductMatchRule {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  matchPattern String // normalized token/string that maps to the product
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Shipments (tracking)
// ─────────────────────────────────────────────────────────────

model Shipment {
  id              String         @id @default(cuid())
  userId          String
  orderId         String
  carrier         String?
  trackingNumber  String
  status          ShipmentStatus @default(PENDING)
  statusUpdatedAt DateTime?
  trackingUrl     String?
  eventsJson      Json? // carrier event history
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, trackingNumber])
  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────────
// Inventory + Sales (profit engine)
// ─────────────────────────────────────────────────────────────

model InventoryStack {
  id                String          @id @default(cuid())
  userId            String
  productId         String
  sourceOrderItemId String?
  quantityInitial   Int             @default(0)
  quantityAvailable Int             @default(0)
  avgCostBasis      Decimal         @default(0) @db.Decimal(12, 2)
  status            InventoryStatus @default(SEALED)
  locationLabel     String?
  currentValue      Decimal?        @db.Decimal(12, 2) // manual market value
  notes             String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceOrderItem OrderItem? @relation(fields: [sourceOrderItemId], references: [id])
  sales           Sale[]

  @@index([userId])
  @@index([productId])
}

model Sale {
  id               String   @id @default(cuid())
  userId           String
  inventoryStackId String?
  productId        String?
  saleDate         DateTime
  marketplace      String? // eBay, StockX, Whatnot, local, etc.
  quantity         Int      @default(1)
  salePriceEach    Decimal  @default(0) @db.Decimal(12, 2)
  fees             Decimal  @default(0) @db.Decimal(12, 2)
  outboundShipping Decimal  @default(0) @db.Decimal(12, 2)
  costBasisEach    Decimal  @default(0) @db.Decimal(12, 2) // snapshot at sale time
  profit           Decimal  @default(0) @db.Decimal(12, 2) // revenue - fees - shipping - cost basis
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryStack InventoryStack? @relation(fields: [inventoryStackId], references: [id])
  product        Product?        @relation(fields: [productId], references: [id])

  @@index([userId, saleDate])
}

// ─────────────────────────────────────────────────────────────
// Attachments, notifications, webhooks, share cards
// ─────────────────────────────────────────────────────────────

model Attachment {
  id         String         @id @default(cuid())
  userId     String
  orderId    String
  type       AttachmentType @default(FILE)
  url        String
  uploadedAt DateTime       @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  body        String?
  payloadJson Json?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model WebhookConfig {
  id        String      @id @default(cuid())
  userId    String
  kind      WebhookKind @default(DISCORD)
  url       String
  events    String[]
  enabled   Boolean     @default(true)
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShareCard {
  id                String   @id @default(cuid())
  userId            String
  template          String   @default("default")
  backgroundRef     String?
  fieldsJson        Json // which stats appear + styling
  generatedImageUrl String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
